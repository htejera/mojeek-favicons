{
  "manifest_version": 3,
  "name": "Mojeek Favicons",
  "version": "1.0.0",
  "description": "Adds a Startpage-style header to Mojeek results: favicon + site name + URL (plain text). Handles indented sitelinks.",
  "icons": {
    "48": "icon.png",
    "96": "icon.png"
  },
  "host_permissions": [
    "*://icons.duckduckgo.com/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "*://*.mojeek.com/search*",
        "*://mojeek.com/search*"
      ],
      "js": [
        "content-script.js"
      ],
      "run_at": "document_idle",
      "all_frames": false
    }
  ]
}
